    "@privy-io/node": "^0.17.0",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.4",
    "bcryptjs": "^2.4.3",
    "buffer": "^6.0.3",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.16.1",
    "next": "^14.0.4",
    "next-auth": "^4.24.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^13.0.0",
    "zod": "^3.22.4"
  },
