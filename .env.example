# Backend Environment Variables Template
# 
# ESTRUTURA:
# - .env              → Desenvolvimento local (usado automaticamente pelo Next.js)
# - .env.production   → Produção (usado pelo PM2 no servidor)
#
# Para desenvolvimento: copie este arquivo para .env
# Para produção: copie este arquivo para .env.production

# Database
DATABASE_URL="mysql://user:password@host:port/database"

# JWT - Secrets (gerar chaves seguras para produção)
# Use: openssl rand -hex 32 (para cada secret)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-minimum-32-characters
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production-minimum-32-characters

# Next.js
# IMPORTANTE: SEMPRE usar produção (https://p2ploot.com) para Discord OAuth
# O callback do Discord sempre vai para produção, mesmo em desenvolvimento
NEXTAUTH_URL=https://p2ploot.com

# CORS
# Desenvolvimento: http://localhost:6111
# Produção: https://p2ploot.com
NEXT_PUBLIC_FRONTEND_URL=http://localhost:6111

# Admin
ADMIN_EMAIL=admin@example.com

# Discord OAuth
# Obter em: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# S3 Compatible Storage (MinIO local / Cloudflare R2 prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=p2ploot
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000/p2ploot

# Web3 / Solana
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_ESCROW_PROGRAM_ID=
SOLANA_VALIDATE_TX_SIGNATURES=false
PLATFORM_FEE_BPS=250

# Local-only devnet demo. Produces real devnet system transfers when wallets
# have test SOL; otherwise records an explicit local fallback event.
SOLANA_DEVNET_DEMO_ENABLED=true
SOLANA_DEVNET_DEMO_FALLBACK_TO_LOCAL=true
SOLANA_DEVNET_DEMO_AUTO_AIRDROP=false
SOLANA_DEVNET_DEMO_RPC_TIMEOUT_MS=12000
SOLANA_DEVNET_DEMO_LAMPORTS=1000000

# Later gas abstraction integration
KORA_RPC_URL=
