# Backend Environment Variables Template
# 
# ESTRUTURA:
# - .env              → Desenvolvimento local (usado automaticamente pelo Next.js)
# - .env.production   → Produção (usado pelo PM2 no servidor)
#
# Para desenvolvimento: copie este arquivo para .env
# Para produção: copie este arquivo para .env.production

# Database
DATABASE_URL="mysql://user:password@host:port/database"

# JWT - Secrets (gerar chaves seguras para produção)
# Use: openssl rand -hex 32 (para cada secret)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-minimum-32-characters
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production-minimum-32-characters

# Next.js
# IMPORTANTE: SEMPRE usar produção (https://p2ploot.com) para Discord OAuth
# O callback do Discord sempre vai para produção, mesmo em desenvolvimento
NEXTAUTH_URL=https://p2ploot.com

# CORS
# Desenvolvimento: http://localhost:6111
# Produção: https://p2ploot.com
NEXT_PUBLIC_FRONTEND_URL=http://localhost:6111

# Admin
ADMIN_EMAIL=admin@example.com

# Discord OAuth
# Obter em: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
